# TML Platform Configuration

# Environment
TML_ENVIRONMENT=development
TML_DEBUG=true
TML_LOG_LEVEL=INFO

# Directories
TML_DATA_DIR=./data
TML_MODEL_DIR=./models
TML_LOGS_DIR=./logs

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=redis123
REDIS_MAX_CONNECTIONS=100

# Kafka Configuration
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TRANSACTION_TOPIC=transactions
KAFKA_MODEL_UPDATES_TOPIC=model_updates
KAFKA_CONSUMER_GROUP=tml_processors

# Cassandra Configuration
CASSANDRA_HOSTS=localhost
CASSANDRA_PORT=9042
CASSANDRA_KEYSPACE=tml_models
CASSANDRA_REPLICATION_FACTOR=1

# MLflow Configuration
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=tml_experiments

# Model Configuration
MODEL_BASE_TYPE=river
MODEL_MAX_IN_MEMORY=10000
MODEL_COMPRESSION_ENABLED=true
MODEL_EWC_LAMBDA=0.4
MODEL_DRIFT_THRESHOLD=0.1
MODEL_COLD_START_SAMPLES=100

# Serving Configuration
RAY_ADDRESS=
SERVING_NUM_REPLICAS=4
SERVING_MAX_CONCURRENT_QUERIES=1000

# Monitoring Configuration
PROMETHEUS_PORT=8000
GRAFANA_URL=http://localhost:3000
MONITORING_DRIFT_CHECK_INTERVAL=300
