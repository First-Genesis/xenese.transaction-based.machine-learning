{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "TML": "Debug"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Database=tml_production;Username=tml_user;Password=tml_prod_2024!"
  },
  "Redis": {
    "ConnectionString": "localhost:6379",
    "DatabaseIndex": 0,
    "KeyPrefix": "tml",
    "DefaultExpiration": "01:00:00",
    "DefaultTransactionExpiration": "00:30:00",
    "DefaultModelExpiration": "02:00:00",
    "DefaultSpatialExpiration": "00:15:00",
    "DefaultMetricsExpiration": "00:05:00"
  },
  "S3": {
    "BucketName": "tml-models",
    "Region": "us-east-1",
    "Environment": "development",
    "UseMinIO": true,
    "ServiceUrl": "http://localhost:9000",
    "AccessKey": "minioadmin",
    "SecretKey": "minioadmin123",
    "ForcePathStyle": true,
    "EnableOfflineMode": false,
    "LocalCachePath": "./cache/models",
    "MaxConcurrentUploads": 10,
    "UploadPartSizeMB": 5,
    "RequestTimeout": "00:05:00"
  },
  "ActorSystem": {
    "ClusterName": "tml-cluster",
    "EnableClustering": false,
    "ConsulHost": "localhost",
    "ConsulPort": 8500,
    "TransactionProcessorCount": 3,
    "ModelActorCount": 5,
    "PhysicsValidatorCount": 2
  },
  "Jwt": {
    "Key": "ThisIsADevelopmentSecretKeyChangeInProduction2024!",
    "Issuer": "TML-Platform",
    "Audience": "TML-Clients",
    "ExpirationMinutes": 60
  },
  "Kafka": {
    "BootstrapServers": "localhost:9092",
    "SchemaRegistryUrl": "http://localhost:8081",
    "ProducerConfig": {
      "Acks": "all",
      "EnableIdempotence": true,
      "MaxInFlight": 5,
      "CompressionType": "snappy",
      "LingerMs": 10
    },
    "ConsumerConfig": {
      "GroupId": "tml-api-consumer",
      "EnableAutoCommit": false,
      "AutoOffsetReset": "earliest",
      "MaxPollIntervalMs": 300000,
      "SessionTimeoutMs": 30000
    },
    "Topics": {
      "Transactions": "tml.transactions",
      "Models": "tml.models",
      "Events": "tml.events",
      "Metrics": "tml.metrics"
    }
  },
  "Monitoring": {
    "PrometheusEndpoint": "http://localhost:9090",
    "GrafanaEndpoint": "http://localhost:3000",
    "JaegerEndpoint": "http://localhost:16686"
  },
  "MLflow": {
    "TrackingUri": "http://localhost:5002",
    "ExperimentName": "TML-Production"
  },
  "FeatureFlags": {
    "EnableBatchProcessing": true,
    "EnablePhysicsValidation": true,
    "EnableModelInheritance": true,
    "EnableOfflineMode": false,
    "EnableDistributedTracing": true,
    "EnableMetricsCollection": true
  },
  "RateLimiting": {
    "PermitLimit": 100,
    "Window": "00:01:00",
    "QueueLimit": 50
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:3000",
      "http://localhost:8081"
    ],
    "AllowedMethods": ["GET", "POST", "PUT", "DELETE", "OPTIONS"],
    "AllowedHeaders": ["*"],
    "AllowCredentials": true
  }
}
